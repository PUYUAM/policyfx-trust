{
  "manifest_version": 3,
  "name": "Policy+FX Trust Layer",
  "version": "0.1.6",
  "description": "One-click access to your real-time央行政策 + USD/CNY + SHCOMP dashboard",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost/*", "https://*/ui/*", "https://PUYUAM.github.io/policyfx-trust/*"],
  "content_scripts": [],
  "web_accessible_resources": [],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Policy+FX Dashboard"
  }
}